foundation module support {
public record Box<T> {
    public value: T,
}

public fn unwrap<T>(box: Box<T>) -> T {
    box.value
}
}

domain module test {
public proof Receipt {
    public count: Int,
}

public fn mint() -> Receipt proves Receipt {
    prove Receipt { count: 7 }
}

public fn boot() -> Receipt {
    support::unwrap<Receipt>(support::Box<Receipt> { value: mint() })
}
}
