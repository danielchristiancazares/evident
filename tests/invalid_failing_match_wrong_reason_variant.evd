domain module test {
public reason ParseFailure {
    Bad,
}

public reason OtherFailure {
    Different,
}

public fn parse() -> Int fails ParseFailure {
    fail Bad
}

public fn main() -> Int {
    match parse() {
        succeeded(value) => value,
        failed(Bad) => 1,
        failed(Different) => 2,
    }
}
}
