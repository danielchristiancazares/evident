boundary module test {
public record CStringBox {
    public value: CString,
}

public fn accept(value: CString) -> CString {
    value
}

public fn return_nul_literal() -> CString {
    "\0"
}

public fn argument_unicode_nul() -> CString {
    accept("\u{0}")
}

public fn field_nul_literal() -> CString {
    CStringBox { value: "\0" }.value
}
}
