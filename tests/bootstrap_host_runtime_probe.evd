import bootstrap_host;

boundary module bootstrap_host_runtime_probe {
public fn main() -> Int {
    let working_directory = bootstrap_host::host_path(".");
    let probe_directory = bootstrap_host::resolve_path(working_directory, bootstrap_host::host_path("bootstrap-host-runtime-probe"));
    let probe_file = bootstrap_host::host_path("bootstrap-host-runtime-probe.txt");
    let probe_contents = bootstrap_host::host_file_contents("bootstrap-host-runtime-probe");
    let ignored = bootstrap_host::write_text_file_text(probe_file.text, probe_contents.text);
    let executable = bootstrap_host::host_path("C:/Windows/System32/cmd.exe");
    let arguments = bootstrap_host::host_path("/c exit 0");
    let ignored_exit = bootstrap_host::spawn_tool_text(working_directory.text, executable.text, arguments.text);
    0
}
}
