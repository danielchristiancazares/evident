public fn copied_empty_map_entries_count() -> Nat {
    let entries = map_entries_copy<Text, Int>(empty_map())
    list_count_copy<MapEntry<Text, Int>>(entries)
}

public fn copied_single_map_entries_value() -> Int {
    let entries = nonempty_map_entries_copy<Text, Int>(single_map())
    let entry = nonempty_list_first_copy<MapEntry<Text, Int>>(entries)
    entry.value
}

public fn consumed_widened_map_entries_value() -> Int {
    let entries = map_consume_entries<Text, Int>(widened_map(single_map()))
    let required = match list_require_nonempty<MapEntry<Text, Int>>(entries) {
        succeeded(actual) => actual,
        failed(ListHadNoElements) => nonempty_map_entries_copy<Text, Int>(single_map()),
    }
    let entry = nonempty_list_first_copy<MapEntry<Text, Int>>(required)
    entry.value
}

public fn consumed_single_map_entries_value() -> Int {
    let entries = nonempty_map_consume_entries<Text, Int>(single_map())
    let consumed = nonempty_list_consume_first<MapEntry<Text, Int>>(entries)
    match list_require_nonempty<MapEntry<Text, Int>>(consumed.rest) {
        succeeded(actual) => {
            let entry = nonempty_list_first_copy<MapEntry<Text, Int>>(actual)
            entry.value
        },
        failed(ListHadNoElements) => consumed.first.value,
    }
}

public fn require_single_list() -> Int {
    let values = single_list()
    let widened = widened_list(values)
    let value_count = list_count(widened)
    let required = match list_require_nonempty<Int>(widened) {
        succeeded(actual) => actual,
        failed(ListHadNoElements) => single_list(),
    }
    first_value(required)
}

public fn require_constructed_lists() -> Int {
    let prepended = prepended_list()
    let prepended_count = nonempty_list_count(prepended)
    let appended = appended_list()
    let appended_count = nonempty_list_count(appended)
    let concatenated = nonempty_list_concat<Int>(appended, prepended)
    let concatenated_count = nonempty_list_count(concatenated)
    let left_nonempty = nonempty_list_concat_left<Int>(prepended, empty_list())
    let right_nonempty = nonempty_list_concat_right<Int>(empty_list(), left_nonempty)
    let consumed = nonempty_list_consume_first<Int>(right_nonempty)
    let consumed_first = consumed.first
    let widened_concat = list_concat<Int>(widened_list(single_list()), empty_list())
    let required = match list_require_nonempty<Int>(widened_concat) {
        succeeded(actual) => actual,
        failed(ListHadNoElements) => single_list(),
    }
    let required_first = first_value(required)
    match list_require_nonempty<Int>(consumed.rest) {
        succeeded(actual) => first_value(actual),
        failed(ListHadNoElements) => consumed_first,
    }
}

public fn main() -> Int {
    let empty_result = require_empty_collections()
    let single_map_result = require_single_map()
    let single_result = require_single_list()
    let constructed_result = require_constructed_lists()
    let copied_map_entry_result = first_single_map_value()
    let consumed_map_entry_result = consume_single_map_entry_value()
    let empty_entries_count = copied_empty_map_entries_count()
    let copied_entries_result = copied_single_map_entries_value()
    let consumed_widened_entries_result = consumed_widened_map_entries_value()
    let consumed_entries_result = consumed_single_map_entries_value()
    let empty_lookup_result = lookup_empty_map_value()
    let lookup_result = lookup_single_map_value()
    let nonempty_lookup_result = lookup_nonempty_single_map_value()
    let int_lookup_result = lookup_int_map_value()
    let missing_lookup_result = lookup_missing_single_map_value()
    let bound_empty_result = bind_empty_map_value()
    let bound_int_result = bind_int_map_first_value()
    let replaced_result = replace_single_map_value()
    let bind_or_replace_result = bind_or_replace_existing_value()
    let bind_or_replace_new_result = bind_or_replace_new_first_value()
    let missing_replace_result = replace_missing_single_map_value()
    let removed_single_result = remove_single_map_then_missing_value()
    let removed_missing_result = remove_missing_map_value()
    let removed_int_result = remove_bound_int_map_value()
    let removed_inserted_first_result = remove_inserted_first_map_value()
    let removed_inserted_last_result = remove_inserted_last_map_value()
    let consumed_single_result = consume_single_bound_value()
    let consumed_missing_result = consume_missing_bound_value()
    let consumed_int_result = consume_bound_int_value()
    let consumed_inserted_first_result = consume_inserted_first_bound_value()
    let consumed_inserted_last_result = consume_inserted_last_bound_value()
    let merged_empty_result = merge_empty_maps_value()
    let merged_reject_result = merge_reject_disjoint_value()
    let merged_left_nonempty_reject_result = merge_left_nonempty_reject_disjoint_value()
    let merged_right_nonempty_reject_result = merge_right_nonempty_reject_disjoint_value()
    let merged_nonempty_reject_result = merge_nonempty_reject_shared_value()
    let merged_left_policy_result = merge_left_policy_duplicate_value()
    let merged_left_nonempty_policy_result = merge_left_nonempty_policy_value()
    let merged_right_nonempty_left_policy_result = merge_right_nonempty_left_policy_value()
    let merged_nonempty_left_policy_result = merge_nonempty_left_policy_value()
    let merged_right_policy_result = merge_right_policy_duplicate_value()
    let merged_left_nonempty_right_policy_result = merge_left_nonempty_right_policy_value()
    let merged_right_nonempty_right_policy_result = merge_right_nonempty_right_policy_value()
    let merged_nonempty_right_policy_result = merge_nonempty_right_policy_value()
    merge_int_right_policy_value()
}
}
