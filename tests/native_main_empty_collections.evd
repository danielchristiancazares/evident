domain module test {
public fn empty_list() -> List<Int> {
    list_empty<Int>()
}

public fn empty_map() -> Map<Text, Int> {
    map_empty<Text, Int>()
}

public fn widened_list(values: NonEmptyList<Int>) -> List<Int> {
    nonempty_list_widen<Int>(values)
}

public fn widened_map(entries: NonEmptyMap<Text, Int>) -> Map<Text, Int> {
    nonempty_map_widen<Text, Int>(entries)
}

public fn list_count(values: List<Int>) -> Nat {
    list_count_copy<Int>(values)
}

public fn nonempty_list_count(values: NonEmptyList<Int>) -> Nat {
    nonempty_list_count_copy<Int>(values)
}

public fn map_count(entries: Map<Text, Int>) -> Nat {
    map_count_copy<Text, Int>(entries)
}

public fn nonempty_map_count(entries: NonEmptyMap<Text, Int>) -> Nat {
    nonempty_map_count_copy<Text, Int>(entries)
}

public fn single_list() -> NonEmptyList<Int> {
    list_single<Int>(7)
}

public fn first_value(values: NonEmptyList<Int>) -> Int {
    nonempty_list_first_copy<Int>(values)
}

public fn prepended_list() -> NonEmptyList<Int> {
    let values = widened_list(single_list())
    list_prepend<Int>(11, values)
}

public fn appended_list() -> NonEmptyList<Int> {
    let values = widened_list(single_list())
    list_append<Int>(values, 13)
}

public fn require_empty_map(entries: Map<Text, Int>) -> Int {
    match map_require_nonempty<Text, Int>(entries) {
        succeeded(actual) => {
            let widened = nonempty_map_widen<Text, Int>(actual)
            5
        },
        failed(MapHadNoEntries) => 7,
    }
}

public fn require_empty_collections() -> Int {
    let values = empty_list()
    let entries = empty_map()
    let value_count = list_count(values)
    let entry_count = map_count(entries)
    match list_require_nonempty<Int>(values) {
        succeeded(actual) => {
            let widened = nonempty_list_widen<Int>(actual)
            3
        },
        failed(ListHadNoElements) => require_empty_map(entries),
    }
}

public fn require_single_list() -> Int {
    let values = single_list()
    let widened = widened_list(values)
    let value_count = list_count(widened)
    let required = match list_require_nonempty<Int>(widened) {
        succeeded(actual) => actual,
        failed(ListHadNoElements) => single_list(),
    }
    first_value(required)
}

public fn require_constructed_lists() -> Int {
    let prepended = prepended_list()
    let prepended_count = nonempty_list_count(prepended)
    let appended = appended_list()
    let appended_count = nonempty_list_count(appended)
    let concatenated = nonempty_list_concat<Int>(appended, prepended)
    let concatenated_count = nonempty_list_count(concatenated)
    let left_nonempty = nonempty_list_concat_left<Int>(prepended, empty_list())
    let right_nonempty = nonempty_list_concat_right<Int>(empty_list(), left_nonempty)
    let widened_concat = list_concat<Int>(widened_list(single_list()), empty_list())
    let required = match list_require_nonempty<Int>(widened_concat) {
        succeeded(actual) => actual,
        failed(ListHadNoElements) => single_list(),
    }
    let required_first = first_value(required)
    first_value(right_nonempty)
}

public fn main() -> Int {
    let empty_result = require_empty_collections()
    let single_result = require_single_list()
    require_constructed_lists()
}
}
