domain module test {
public fn empty_list() -> List<Int> {
    list_empty<Int>()
}

public fn empty_map() -> Map<Text, Int> {
    map_empty<Text, Int>()
}

public fn single_map() -> NonEmptyMap<Text, Int> {
    map_single<Text, Int>("one", 7)
}

public fn alpha_map() -> NonEmptyMap<Text, Int> {
    map_single<Text, Int>("alpha", 13)
}

public fn replacement_map() -> NonEmptyMap<Text, Int> {
    map_single<Text, Int>("one", 9)
}

