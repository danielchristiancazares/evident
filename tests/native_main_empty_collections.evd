domain module test {
public fn empty_list() -> List<Int> {
    list_empty<Int>()
}

public fn empty_map() -> Map<Text, Int> {
    map_empty<Text, Int>()
}

public fn single_map() -> NonEmptyMap<Text, Int> {
    map_single<Text, Int>("one", 7)
}

public fn single_int_map() -> NonEmptyMap<Int, Int> {
    map_single<Int, Int>(4, 7)
}

public fn widened_list(values: NonEmptyList<Int>) -> List<Int> {
    nonempty_list_widen<Int>(values)
}

public fn widened_map(entries: NonEmptyMap<Text, Int>) -> Map<Text, Int> {
    nonempty_map_widen<Text, Int>(entries)
}

public fn widened_int_map(entries: NonEmptyMap<Int, Int>) -> Map<Int, Int> {
    nonempty_map_widen<Int, Int>(entries)
}

public fn list_count(values: List<Int>) -> Nat {
    list_count_copy<Int>(values)
}

public fn nonempty_list_count(values: NonEmptyList<Int>) -> Nat {
    nonempty_list_count_copy<Int>(values)
}

public fn map_count(entries: Map<Text, Int>) -> Nat {
    map_count_copy<Text, Int>(entries)
}

public fn nonempty_map_count(entries: NonEmptyMap<Text, Int>) -> Nat {
    nonempty_map_count_copy<Text, Int>(entries)
}

public fn single_list() -> NonEmptyList<Int> {
    list_single<Int>(7)
}

public fn first_value(values: NonEmptyList<Int>) -> Int {
    nonempty_list_first_copy<Int>(values)
}

public fn prepended_list() -> NonEmptyList<Int> {
    let values = widened_list(single_list())
    list_prepend<Int>(11, values)
}

public fn appended_list() -> NonEmptyList<Int> {
    let values = widened_list(single_list())
    list_append<Int>(values, 13)
}

public fn require_empty_map(entries: Map<Text, Int>) -> Int {
    match map_require_nonempty<Text, Int>(entries) {
        succeeded(actual) => {
            let widened = nonempty_map_widen<Text, Int>(actual)
            5
        },
        failed(MapHadNoEntries) => 7,
    }
}

public fn require_empty_collections() -> Int {
    let values = empty_list()
    let entries = empty_map()
    let value_count = list_count(values)
    let entry_count = map_count(entries)
    match list_require_nonempty<Int>(values) {
        succeeded(actual) => {
            let widened = nonempty_list_widen<Int>(actual)
            3
        },
        failed(ListHadNoElements) => require_empty_map(entries),
    }
}

public fn require_single_map() -> Nat {
    let entries = single_map()
    let widened = widened_map(entries)
    map_count(widened)
}

public fn first_single_map_value() -> Int {
    let entry = nonempty_map_first_entry_copy<Text, Int>(single_map())
    entry.value
}

public fn consume_single_map_entry_value() -> Int {
    let consumed = nonempty_map_consume_first_entry<Text, Int>(single_map())
    match map_require_nonempty<Text, Int>(consumed.rest) {
        succeeded(actual) => {
            let entry = nonempty_map_first_entry_copy<Text, Int>(actual)
            entry.value
        },
        failed(MapHadNoEntries) => consumed.first.value,
    }
}

public fn lookup_empty_map_value() -> Int {
    match map_lookup_copy<Text, Int>(empty_map(), "missing") {
        succeeded(value) => value,
        failed(RequestedKeyHadNoBinding) => 7,
        failed(RequestedKeyAlreadyHadBinding) => 3,
    }
}

public fn lookup_single_map_value() -> Int {
    match map_lookup_copy<Text, Int>(widened_map(single_map()), "one") {
        succeeded(value) => value,
        failed(RequestedKeyHadNoBinding) => 3,
        failed(RequestedKeyAlreadyHadBinding) => 3,
    }
}

public fn lookup_nonempty_single_map_value() -> Int {
    match nonempty_map_lookup_copy<Text, Int>(single_map(), "one") {
        succeeded(value) => value,
        failed(RequestedKeyHadNoBinding) => 3,
        failed(RequestedKeyAlreadyHadBinding) => 3,
    }
}

public fn lookup_missing_single_map_value() -> Int {
    match nonempty_map_lookup_copy<Text, Int>(single_map(), "two") {
        succeeded(value) => value,
        failed(RequestedKeyHadNoBinding) => 7,
        failed(RequestedKeyAlreadyHadBinding) => 3,
    }
}

public fn lookup_int_map_value() -> Int {
    match map_lookup_copy<Int, Int>(widened_int_map(single_int_map()), 4) {
        succeeded(value) => value,
        failed(RequestedKeyHadNoBinding) => 3,
        failed(RequestedKeyAlreadyHadBinding) => 3,
    }
}

public fn bind_empty_map_value() -> Int {
    match map_bind_new<Text, Int>(empty_map(), "alpha", 11) {
        succeeded(entries) => {
            let entry = nonempty_map_first_entry_copy<Text, Int>(entries)
            entry.value
        },
        failed(RequestedKeyHadNoBinding) => 3,
        failed(RequestedKeyAlreadyHadBinding) => 5,
    }
}

public fn bind_duplicate_single_map_value() -> Int {
    match nonempty_map_bind_new<Text, Int>(single_map(), "one", 9) {
        succeeded(entries) => {
            let entry = nonempty_map_first_entry_copy<Text, Int>(entries)
            entry.value
        },
        failed(RequestedKeyHadNoBinding) => 3,
        failed(RequestedKeyAlreadyHadBinding) => 7,
    }
}

public fn bind_int_map_first_value() -> Int {
    match map_bind_new<Int, Int>(widened_int_map(single_int_map()), 3, 11) {
        succeeded(entries) => {
            let entry = nonempty_map_first_entry_copy<Int, Int>(entries)
            entry.value
        },
        failed(RequestedKeyHadNoBinding) => 3,
        failed(RequestedKeyAlreadyHadBinding) => 5,
    }
}

public fn replace_single_map_value() -> Int {
    match nonempty_map_replace_bound<Text, Int>(single_map(), "one", 9) {
        succeeded(entries) => {
            match nonempty_map_lookup_copy<Text, Int>(entries, "one") {
                succeeded(value) => value,
                failed(RequestedKeyHadNoBinding) => 3,
                failed(RequestedKeyAlreadyHadBinding) => 3,
            }
        },
        failed(RequestedKeyHadNoBinding) => 3,
        failed(RequestedKeyAlreadyHadBinding) => 3,
    }
}

public fn replace_missing_single_map_value() -> Int {
    match map_replace_bound<Text, Int>(widened_map(single_map()), "two", 9) {
        succeeded(entries) => {
            let entry = nonempty_map_first_entry_copy<Text, Int>(entries)
            entry.value
        },
        failed(RequestedKeyHadNoBinding) => 7,
        failed(RequestedKeyAlreadyHadBinding) => 3,
    }
}

public fn bind_or_replace_existing_value() -> Int {
    let entries = map_bind_or_replace<Text, Int>(widened_map(single_map()), "one", 9)
    match nonempty_map_lookup_copy<Text, Int>(entries, "one") {
        succeeded(value) => value,
        failed(RequestedKeyHadNoBinding) => 3,
        failed(RequestedKeyAlreadyHadBinding) => 3,
    }
}

public fn bind_or_replace_new_first_value() -> Int {
    let entries = nonempty_map_bind_or_replace<Text, Int>(single_map(), "alpha", 13)
    let entry = nonempty_map_first_entry_copy<Text, Int>(entries)
    entry.value
}

public fn copied_empty_map_entries_count() -> Nat {
    let entries = map_entries_copy<Text, Int>(empty_map())
    list_count_copy<MapEntry<Text, Int>>(entries)
}

public fn copied_single_map_entries_value() -> Int {
    let entries = nonempty_map_entries_copy<Text, Int>(single_map())
    let entry = nonempty_list_first_copy<MapEntry<Text, Int>>(entries)
    entry.value
}

public fn consumed_widened_map_entries_value() -> Int {
    let entries = map_consume_entries<Text, Int>(widened_map(single_map()))
    let required = match list_require_nonempty<MapEntry<Text, Int>>(entries) {
        succeeded(actual) => actual,
        failed(ListHadNoElements) => nonempty_map_entries_copy<Text, Int>(single_map()),
    }
    let entry = nonempty_list_first_copy<MapEntry<Text, Int>>(required)
    entry.value
}

public fn consumed_single_map_entries_value() -> Int {
    let entries = nonempty_map_consume_entries<Text, Int>(single_map())
    let consumed = nonempty_list_consume_first<MapEntry<Text, Int>>(entries)
    match list_require_nonempty<MapEntry<Text, Int>>(consumed.rest) {
        succeeded(actual) => {
            let entry = nonempty_list_first_copy<MapEntry<Text, Int>>(actual)
            entry.value
        },
        failed(ListHadNoElements) => consumed.first.value,
    }
}

public fn require_single_list() -> Int {
    let values = single_list()
    let widened = widened_list(values)
    let value_count = list_count(widened)
    let required = match list_require_nonempty<Int>(widened) {
        succeeded(actual) => actual,
        failed(ListHadNoElements) => single_list(),
    }
    first_value(required)
}

public fn require_constructed_lists() -> Int {
    let prepended = prepended_list()
    let prepended_count = nonempty_list_count(prepended)
    let appended = appended_list()
    let appended_count = nonempty_list_count(appended)
    let concatenated = nonempty_list_concat<Int>(appended, prepended)
    let concatenated_count = nonempty_list_count(concatenated)
    let left_nonempty = nonempty_list_concat_left<Int>(prepended, empty_list())
    let right_nonempty = nonempty_list_concat_right<Int>(empty_list(), left_nonempty)
    let consumed = nonempty_list_consume_first<Int>(right_nonempty)
    let consumed_first = consumed.first
    let widened_concat = list_concat<Int>(widened_list(single_list()), empty_list())
    let required = match list_require_nonempty<Int>(widened_concat) {
        succeeded(actual) => actual,
        failed(ListHadNoElements) => single_list(),
    }
    let required_first = first_value(required)
    match list_require_nonempty<Int>(consumed.rest) {
        succeeded(actual) => first_value(actual),
        failed(ListHadNoElements) => consumed_first,
    }
}

public fn main() -> Int {
    let empty_result = require_empty_collections()
    let single_map_result = require_single_map()
    let single_result = require_single_list()
    let constructed_result = require_constructed_lists()
    let copied_map_entry_result = first_single_map_value()
    let consumed_map_entry_result = consume_single_map_entry_value()
    let empty_entries_count = copied_empty_map_entries_count()
    let copied_entries_result = copied_single_map_entries_value()
    let consumed_widened_entries_result = consumed_widened_map_entries_value()
    let consumed_entries_result = consumed_single_map_entries_value()
    let empty_lookup_result = lookup_empty_map_value()
    let lookup_result = lookup_single_map_value()
    let nonempty_lookup_result = lookup_nonempty_single_map_value()
    let int_lookup_result = lookup_int_map_value()
    let missing_lookup_result = lookup_missing_single_map_value()
    let bound_empty_result = bind_empty_map_value()
    let bound_int_result = bind_int_map_first_value()
    let replaced_result = replace_single_map_value()
    let bind_or_replace_result = bind_or_replace_existing_value()
    let bind_or_replace_new_result = bind_or_replace_new_first_value()
    let missing_replace_result = replace_missing_single_map_value()
    bind_duplicate_single_map_value()
}
}
