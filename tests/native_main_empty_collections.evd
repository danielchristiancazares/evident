}

public fn prepended_list() -> NonEmptyList<Int> {
    let values = widened_list(single_list())
    list_prepend<Int>(11, values)
}

public fn appended_list() -> NonEmptyList<Int> {
    let values = widened_list(single_list())
    list_append<Int>(values, 13)
}

public fn require_empty_map(entries: Map<Text, Int>) -> Int {
    match map_require_nonempty<Text, Int>(entries) {
        succeeded(actual) => {
            let widened = nonempty_map_widen<Text, Int>(actual)
            5
        },
        failed(MapHadNoEntries) => 7,
    }
}

public fn require_empty_collections() -> Int {
    let values = empty_list()
    let entries = empty_map()
    let value_count = list_count(values)
    let entry_count = map_count(entries)
    match list_require_nonempty<Int>(values) {
        succeeded(actual) => {
            let widened = nonempty_list_widen<Int>(actual)
            3
        },
        failed(ListHadNoElements) => require_empty_map(entries),
    }
}

public fn require_single_map() -> Nat {
    let entries = single_map()
    let widened = widened_map(entries)
    map_count(widened)
}

