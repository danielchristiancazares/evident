types:
  - public proof test::Receipt [affine]
      field count: Int
  - public record test::Envelope [affine]
      field receipt: test::Receipt [affine]
functions:
  - public fn test::mint() -> test::Receipt [affine] proves test::Receipt
      block -> test::Receipt [affine]
        result
          prove test::Receipt : test::Receipt [affine]
            init count
              number 7 : Int
  - public fn test::wrap(receipt: test::Receipt [affine]) -> test::Envelope [affine]
      block -> test::Envelope [affine]
        result
          construct test::Envelope : test::Envelope [affine]
            init receipt [shorthand]
              local receipt : test::Receipt [affine]
  - public fn test::boot() -> test::Envelope [affine]
      block -> test::Envelope [affine]
        let receipt: test::Receipt [affine]
          call test::mint -> test::Receipt [affine]
        result
          call test::wrap -> test::Envelope [affine]
            local receipt : test::Receipt [affine]
