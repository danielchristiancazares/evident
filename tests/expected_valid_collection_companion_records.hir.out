types:
  - public reason ListCardinalityFailure
      variant ListHadNoElements
  - public reason MapCardinalityFailure
      variant MapHadNoEntries
  - public reason MapBindingFailure
      variant RequestedKeyHadNoBinding
      variant RequestedKeyAlreadyHadBinding
  - public reason MapMergeFailure
      variant InputsHadSharedKey
  - public record test::CollectionCompanions
      field first_int: ListFirstAndRest<Int>
      field text_entry: MapEntry<Text, Int>
      field first_entry: MapFirstEntryAndRest<Text, Int>
      field bound_value: MapBoundValueAndRest<Bytes, Text>
functions:
  - public fn list_empty<T>() -> List<T>
  - public fn list_single<T>(value: T) -> NonEmptyList<T>
  - public fn list_prepend<T>(value: T, values: List<T>) -> NonEmptyList<T>
  - public fn list_append<T>(values: List<T>, value: T) -> NonEmptyList<T>
  - public fn list_concat<T>(left: List<T>, right: List<T>) -> List<T>
  - public fn nonempty_list_concat_left<T>(left: NonEmptyList<T>, right: List<T>) -> NonEmptyList<T>
  - public fn nonempty_list_concat_right<T>(left: List<T>, right: NonEmptyList<T>) -> NonEmptyList<T>
  - public fn nonempty_list_concat<T>(left: NonEmptyList<T>, right: NonEmptyList<T>) -> NonEmptyList<T>
  - public fn list_require_nonempty<T>(values: List<T>) -> NonEmptyList<T> fails ListCardinalityFailure
  - public fn nonempty_list_widen<T>(values: NonEmptyList<T>) -> List<T>
  - public fn list_count_copy<T>(values: List<T>) -> Nat
  - public fn nonempty_list_count_copy<T>(values: NonEmptyList<T>) -> Nat
  - public fn nonempty_list_first_copy<T>(values: NonEmptyList<T>) -> T
  - public fn nonempty_list_consume_first<T>(values: NonEmptyList<T>) -> ListFirstAndRest<T>
  - public fn test::keep_first(first: ListFirstAndRest<Int>) -> ListFirstAndRest<Int>
      block -> ListFirstAndRest<Int>
        result
          local first : ListFirstAndRest<Int>
  - public fn test::keep_entry(entry: MapEntry<Text, Int>) -> MapEntry<Text, Int>
      block -> MapEntry<Text, Int>
        result
          local entry : MapEntry<Text, Int>
  - public fn test::list_first_value(first: ListFirstAndRest<Int>) -> Int
      block -> Int
        result
          field-access .first : Int
            local first : ListFirstAndRest<Int>
  - public fn test::list_rest_values(first: ListFirstAndRest<Int>) -> List<Int>
      block -> List<Int>
        result
          field-access .rest : List<Int>
            local first : ListFirstAndRest<Int>
  - public fn test::entry_key(entry: MapEntry<Text, Int>) -> Text
      block -> Text
        result
          field-access .key : Text
            local entry : MapEntry<Text, Int>
  - public fn test::entry_value(entry: MapEntry<Text, Int>) -> Int
      block -> Int
        result
          field-access .value : Int
            local entry : MapEntry<Text, Int>
  - public fn test::map_first_entry(first: MapFirstEntryAndRest<Text, Int>) -> MapEntry<Text, Int>
      block -> MapEntry<Text, Int>
        result
          field-access .first : MapEntry<Text, Int>
            local first : MapFirstEntryAndRest<Text, Int>
  - public fn test::map_first_key(first: MapFirstEntryAndRest<Text, Int>) -> Text
      block -> Text
        result
          field-access .key : Text
            field-access .first : MapEntry<Text, Int>
              local first : MapFirstEntryAndRest<Text, Int>
  - public fn test::map_rest(first: MapFirstEntryAndRest<Text, Int>) -> Map<Text, Int>
      block -> Map<Text, Int>
        result
          field-access .rest : Map<Text, Int>
            local first : MapFirstEntryAndRest<Text, Int>
  - public fn test::bound_value(bound: MapBoundValueAndRest<Bytes, Text>) -> Text
      block -> Text
        result
          field-access .value : Text
            local bound : MapBoundValueAndRest<Bytes, Text>
  - public fn test::bound_rest(bound: MapBoundValueAndRest<Bytes, Text>) -> Map<Bytes, Text>
      block -> Map<Bytes, Text>
        result
          field-access .rest : Map<Bytes, Text>
            local bound : MapBoundValueAndRest<Bytes, Text>
  - public fn test::fail_empty_list() -> Int fails ListCardinalityFailure
      block -> Never
        result
          fail ListCardinalityFailure::ListHadNoElements
  - public fn test::fail_empty_map() -> Int fails MapCardinalityFailure
      block -> Never
        result
          fail MapCardinalityFailure::MapHadNoEntries
  - public fn test::fail_missing_binding() -> Int fails MapBindingFailure
      block -> Never
        result
          fail MapBindingFailure::RequestedKeyHadNoBinding
  - public fn test::fail_existing_binding() -> Int fails MapBindingFailure
      block -> Never
        result
          fail MapBindingFailure::RequestedKeyAlreadyHadBinding
  - public fn test::recover_binding() -> Int
      block -> Int
        result
          match -> Int
            scrutinee
              call test::fail_missing_binding -> Int fails
            arm
              pattern succeeded(value)
              local value : Int
            arm
              pattern failed
                pattern MapBindingFailure::RequestedKeyHadNoBinding
              number 1 : Int
            arm
              pattern failed
                pattern MapBindingFailure::RequestedKeyAlreadyHadBinding
              number 2 : Int
  - public fn test::fail_shared_key() -> Int fails MapMergeFailure
      block -> Never
        result
          fail MapMergeFailure::InputsHadSharedKey
  - public fn test::use_list_operations(values: List<Int>, more: List<Int>, nonempty: NonEmptyList<Int>, value: Int) -> ListFirstAndRest<Int>
      block -> ListFirstAndRest<Int>
        let empty: List<Int>
          call list_empty<Int> -> List<Int>
        let single: NonEmptyList<Int>
          call list_single<Int> -> NonEmptyList<Int>
            local value : Int
        let prepended: NonEmptyList<Int>
          call list_prepend<Int> -> NonEmptyList<Int>
            local value : Int
            local values : List<Int>
        let appended: NonEmptyList<Int>
          call list_append<Int> -> NonEmptyList<Int>
            local values : List<Int>
            local value : Int
        let concatenated: List<Int>
          call list_concat<Int> -> List<Int>
            local values : List<Int>
            local more : List<Int>
        let left_nonempty: NonEmptyList<Int>
          call nonempty_list_concat_left<Int> -> NonEmptyList<Int>
            local nonempty : NonEmptyList<Int>
            local values : List<Int>
        let right_nonempty: NonEmptyList<Int>
          call nonempty_list_concat_right<Int> -> NonEmptyList<Int>
            local values : List<Int>
            local nonempty : NonEmptyList<Int>
        let both_nonempty: NonEmptyList<Int>
          call nonempty_list_concat<Int> -> NonEmptyList<Int>
            local nonempty : NonEmptyList<Int>
            local nonempty : NonEmptyList<Int>
        let required: NonEmptyList<Int>
          match -> NonEmptyList<Int>
            scrutinee
              call list_require_nonempty<Int> -> NonEmptyList<Int> fails
                local values : List<Int>
            arm
              pattern succeeded(actual)
              local actual : NonEmptyList<Int>
            arm
              pattern failed
                pattern ListCardinalityFailure::ListHadNoElements
              local single : NonEmptyList<Int>
        let widened: List<Int>
          call nonempty_list_widen<Int> -> List<Int>
            local required : NonEmptyList<Int>
        let count: Nat
          call list_count_copy<Int> -> Nat
            local widened : List<Int>
        let nonempty_count: Nat
          call nonempty_list_count_copy<Int> -> Nat
            local both_nonempty : NonEmptyList<Int>
        let first: Int
          call nonempty_list_first_copy<Int> -> Int
            local nonempty : NonEmptyList<Int>
        result
          call nonempty_list_consume_first<Int> -> ListFirstAndRest<Int>
            local nonempty : NonEmptyList<Int>
