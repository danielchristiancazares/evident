types:
  - public proof test::Receipt [affine]
      field count: Int
  - public record test::Wrapper [affine]
      field value: test::Receipt [affine]
functions:
  - public fn test::take(wrapper: test::Wrapper [affine]) -> test::Wrapper [affine]
      block -> test::Wrapper [affine]
        result
          local wrapper : test::Wrapper [affine]
