domain module test {
public reason OpenFailure {
    Denied,
}

public reason ParseFailure {
    Bad,
}

public fn acquire() -> Int fails OpenFailure {
    fail Denied
}

public fn value() -> Int {
    1
}

public fn bad_try_reason() -> Int fails ParseFailure {
    try acquire()
}

public fn bad_try_non_failing() -> Int fails ParseFailure {
    try value()
}

public fn bad_fail_outside() -> Int {
    fail Bad
}
}
