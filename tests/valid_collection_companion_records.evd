domain module test {
public record CollectionCompanions {
    public first_int: ListFirstAndRest<Int>,
    public text_entry: MapEntry<Text, Int>,
    public first_entry: MapFirstEntryAndRest<Text, Int>,
    public bound_value: MapBoundValueAndRest<Bytes, Text>,
}

public fn keep_first(first: ListFirstAndRest<Int>) -> ListFirstAndRest<Int> {
    first
}

public fn keep_entry(entry: MapEntry<Text, Int>) -> MapEntry<Text, Int> {
    entry
}

public fn list_first_value(first: ListFirstAndRest<Int>) -> Int {
    first.first
}

public fn list_rest_values(first: ListFirstAndRest<Int>) -> List<Int> {
    first.rest
}

public fn entry_key(entry: MapEntry<Text, Int>) -> Text {
    entry.key
}

public fn entry_value(entry: MapEntry<Text, Int>) -> Int {
    entry.value
}

public fn map_first_entry(first: MapFirstEntryAndRest<Text, Int>) -> MapEntry<Text, Int> {
    first.first
}

public fn map_first_key(first: MapFirstEntryAndRest<Text, Int>) -> Text {
    first.first.key
}

public fn map_rest(first: MapFirstEntryAndRest<Text, Int>) -> Map<Text, Int> {
    first.rest
}

public fn bound_value(bound: MapBoundValueAndRest<Bytes, Text>) -> Text {
    bound.value
}

public fn bound_rest(bound: MapBoundValueAndRest<Bytes, Text>) -> Map<Bytes, Text> {
    bound.rest
}

public fn fail_empty_list() -> Int fails ListCardinalityFailure {
    fail ListHadNoElements
}

public fn fail_empty_map() -> Int fails MapCardinalityFailure {
    fail MapHadNoEntries
}

public fn fail_missing_binding() -> Int fails MapBindingFailure {
    fail RequestedKeyHadNoBinding
}

public fn fail_existing_binding() -> Int fails MapBindingFailure {
    fail MapBindingFailure::RequestedKeyAlreadyHadBinding
}

public fn recover_binding() -> Int {
    match fail_missing_binding() {
        succeeded(value) => value,
        failed(RequestedKeyHadNoBinding) => 1,
        failed(RequestedKeyAlreadyHadBinding) => 2,
    }
}

public fn fail_shared_key() -> Int fails MapMergeFailure {
    fail InputsHadSharedKey
}

public fn use_list_operations(values: List<Int>, more: List<Int>, nonempty: NonEmptyList<Int>, value: Int) -> ListFirstAndRest<Int> {
    let empty = list_empty<Int>()
    let single = list_single<Int>(value)
    let prepended = list_prepend<Int>(value, values)
    let appended = list_append<Int>(values, value)
    let concatenated = list_concat<Int>(values, more)
    let left_nonempty = nonempty_list_concat_left<Int>(nonempty, values)
    let right_nonempty = nonempty_list_concat_right<Int>(values, nonempty)
    let both_nonempty = nonempty_list_concat<Int>(nonempty, nonempty)
    let required = match list_require_nonempty<Int>(values) {
        succeeded(actual) => actual,
        failed(ListHadNoElements) => single,
    }
    let widened = nonempty_list_widen<Int>(required)
    let count = list_count_copy<Int>(widened)
    let nonempty_count = nonempty_list_count_copy<Int>(both_nonempty)
    let first = nonempty_list_first_copy<Int>(nonempty)
    nonempty_list_consume_first<Int>(nonempty)
}
}
