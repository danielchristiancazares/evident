domain module test {
record Missing {
    Default: Int,
}

state Unknown {
    Ready,
    Connected { Missing: Int },
}

reason Other {
    Invalid,
}

proof Any {
    All: Int,
}

permit X

phase Disconnected {
    fields {
        Unrestricted: Int,
    }

    positions {
        Ready,
    }
}

fn No() -> Int {
    0
}

public record PublicReservedPrivateFields {
    Missing: Int,
    Any: Int,
}

public proof PublicReservedPrivateProofFields {
    All: Int,
}

public phase PublicReservedPrivatePhaseFields {
    fields {
        Missing: Int,
    }

    positions {
        Settled,
    }
}

public phase AppConfig {
    fields {
        public id: Int,
        public payload: Int,
    }

    positions {
        Draft,
        Validated,
    }
}

public fn make_draft() -> AppConfig::Draft {
    AppConfig::Draft { id: 7, payload: 2 }
}

public fn validate(config: AppConfig::Draft) -> AppConfig::Validated {
    AppConfig::Validated { id: config.id, payload: 3 }
}
}
