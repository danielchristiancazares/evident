domain module test {
public reason OpenFailure {
    FileNotFound,
}

public reason ParseFailure {
    BadSyntax,
}

public record FileHandle {
    raw: Int,
}

public fn boot() -> FileHandle fails OpenFailure {
    fail BadSyntax
}

public fn fail_with_wrong_collection_reason_variant() -> Int fails MapBindingFailure {
    fail ListHadNoElements
}
}
