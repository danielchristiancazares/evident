domain module test {
public permit RenderPassActive

public reason DrawFailure {
    Denied,
    Rejected,
}

public fn start_pass() -> Unit grants RenderPassActive fails DrawFailure {
    fail Denied
}

public fn submit(as pass: RenderPassActive) -> Int fails DrawFailure {
    fail Rejected
}

public fn draw() -> Int {
    match grant start_pass() as pass {
        submit(as pass)
    } {
        succeeded(count) => count,
        failed(Denied) => 1,
        failed(Rejected) => 2,
    }
}
}
