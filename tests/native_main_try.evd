domain module test {
public reason OpenFailure {
    FileNotFound { path: Text },
}

public fn open(raw: Int) -> Int fails OpenFailure {
    raw
}

public fn boot() -> Int fails OpenFailure {
    try open(11)
}

public fn main() -> Int {
    match boot() {
        succeeded(value) => value,
        failed(FileNotFound { path }) => 2,
    }
}
}
