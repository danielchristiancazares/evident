foundation module support {
record Box<Item, Item> {
    value: Item,
}

fn identity<Value, Value>(value: Value) -> Value {
    value
}
}

domain module test {
record DuplicateRecordFields {
    value: Int,
    value: Text,
}

state DuplicateStateVariants {
    StateAlpha,
    StateAlpha,
}

state VariantFieldShape {
    WithPayload { code: Int, code: Text },
}

reason DuplicateReasonVariants {
    ReasonAlpha,
    ReasonAlpha,
}

reason ReasonFieldShape {
    WithPayload { code: Int, code: Text },
}

proof Receipt {
    count: Int,
    count: Text,
}

phase PhaseShape {
    fields {
        id: Int,
        id: Text,
    }
    positions {
        PhaseDraft,
    }
}

}

boundary module ffi {
foreign fn duplicate_params(value: CInt, value: CInt) -> CInt

fn duplicate_value_params(value: Int, value: Int) -> Int {
    value
}

fn duplicate_local_binding() -> Int {
    let value = 1;
    let value = 2;
    value
}
}
