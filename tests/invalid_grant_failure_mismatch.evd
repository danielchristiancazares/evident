domain module test {
public permit RenderPassActive

public reason StartFailure {
    Denied,
}

public reason SubmitFailure {
    Rejected,
}

public fn start_pass() -> Unit grants RenderPassActive fails StartFailure {
    fail Denied
}

public fn submit(as pass: RenderPassActive) -> Int fails SubmitFailure {
    fail Rejected
}

public fn draw() -> Int {
    grant start_pass() as pass {
        submit(as pass)
    }
}
}
