domain module test {
public reason ParseFailure {
    Bad,
    MissingKey { key: Text },
}

public record Config {
    raw: Text,
}

public fn parse(raw: Text) -> Config fails ParseFailure {
    fail Bad
}

public fn boot(raw: Text) -> Config {
    match parse(raw) {
        succeeded(config) => config,
        failed(Bad) => Config { raw: "fallback" },
        failed(MissingKey { key }) => Config { raw: key },
    }
}
}
